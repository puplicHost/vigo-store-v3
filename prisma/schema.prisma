// 1. الإعدادات الأساسية
generator client {
  provider = "prisma-client-js"
  // شيلنا الـ output المخصص عشان نعتمد على المسار الافتراضي node_modules
  // وده بيسهل التعامل مع Prisma Client في الـ server routes
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 2. نظام الأدوار (Roles)
enum Role {
  USER
  SALES
  MANAGER
  ADMIN
  SUPER_ADMIN
}

// 3. نظام حالات الطلب
enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

// 4. موديل المستخدم
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String    
  image         String?
  role          Role      @default(USER)
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 5. موديل المنتجات
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique 
  description String?
  price       Float
  discount    Float?   
  images      String[] 
  sizes       String[] 
  colors      String[] 
  stock       Int      @default(0)
  isFeatured  Boolean  @default(false)
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 6. التصنيفات
model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

// 7. الطلبات
model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  totalAmount     Float
  status          OrderStatus @default(PENDING)
  paymentIntentId String?     @unique 
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   
}

// 8. إعدادات المتجر (Settings) - Singleton model
model Settings {
  id                String   @id @default(cuid())
  
  // Shipping & Currency
  shippingFee       Float    @default(0)
  currency          String   @default("EGP")
  
  // Contact Info
  contactEmail      String?
  contactPhone      String?
  contactAddress    String?
  whatsappNumber    String?
  
  // Maintenance Mode
  maintenanceMode   Boolean  @default(false)
  maintenanceMessage String?
  
  // SEO
  siteName          String?
  siteDescription   String?
  siteKeywords      String?
  
  // Social Media
  facebookUrl       String?
  instagramUrl      String?
  twitterUrl        String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}