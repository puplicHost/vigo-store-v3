// 1. الإعدادات الأساسية
generator client {
  provider = "prisma-client-js"
  // شيلنا الـ output المخصص عشان نعتمد على المسار الافتراضي node_modules
  // وده بيسهل التعامل مع Prisma Client في الـ server routes
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Connection pool configuration for production
  // Adjust based on your database server capacity
  // connection_limit = env("DATABASE_POOL_SIZE") ? parseInt(env("DATABASE_POOL_SIZE")) : 10
  // pool_timeout = env("DATABASE_POOL_TIMEOUT") ? parseInt(env("DATABASE_POOL_TIMEOUT")) : 2
}

// 2. نظام الأدوار (Roles)
enum Role {
  USER
  SALES
  MANAGER
  ADMIN
  SUPER_ADMIN
}

// 2.1 نظام الصلاحيات (Permissions)
enum Permission {
  VIEW_PRODUCTS
  CREATE_PRODUCTS
  EDIT_PRODUCTS
  DELETE_PRODUCTS
  VIEW_CATEGORIES
  MANAGE_CATEGORIES
  VIEW_ORDERS
  UPDATE_ORDER_STATUS
  VIEW_USERS
  MANAGE_USERS
  MANAGE_SETTINGS
}

// 3. نظام حالات الطلب
enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

// 3.1 نظام حالات الدفع
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// 4. موديل المستخدم
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String    
  image         String?
  role          Role      @default(USER)
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 4.1 ربط الصلاحيات بالأدوار
model RolePermission {
  id          String     @id @default(cuid())
  role        Role
  permission  Permission
  @@unique([role, permission], name: "role_permission")
}

// 5. موديل المنتجات
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique 
  description String?
  price       Float
  discount    Float?   
  images      String[] 
  sizes       String[] 
  colors      String[] 
  stock       Int      @default(0)
  isFeatured  Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  
  categoryId  String
  category    Category @relation("CategoryProducts", fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isDeleted, isActive])
  @@index([categoryId])
  @@index([createdAt])
}

// 6. التصنيفات
model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[] @relation("CategoryProducts")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

// 7. الطلبات
model Order {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  items           OrderItem[]
  payments        PaymentTransaction[]
  totalAmount     Float
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   String        @default("COD")
  shippingAddress String?
  paymentIntentId String?       @unique
  transactionId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Float   
}

// 8. بوابات الدفع (MVP)
model PaymentGateway {
  id              String   @id @default(cuid())
  name            String   @unique // "Paymob", "COD"
  isEnabled       Boolean  @default(true)
  config          Json?    // Stores API Keys, Integration IDs, etc. (Encrypted ideally)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 9. المعاملات المالية
model PaymentTransaction {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  externalId      String?  @unique // Paymob Transaction ID
  amount          Float
  status          String   // "PENDING", "SUCCESS", "FAILED"
  rawResponse     Json?    // Full gateway response for debugging
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 10. إعدادات المتجر (Settings)
model Settings {
  id                String   @id @default("default")
  siteName          String?  @default("VIGO ATELIER")
  siteDescription   String?
  siteKeywords      String?
  currency          String   @default("EGP")
  
  shippingFee       Float    @default(0)
  freeShippingThreshold Float @default(0)

  contactEmail      String?
  contactPhone      String?
  contactAddress    String?
  whatsappNumber    String?
  
  // Social Media
  facebookUrl       String?
  instagramUrl      String?
  twitterUrl        String?
  linkedinUrl       String?
  tiktokUrl         String?
  snapchatUrl       String?

  // Maintenance
  maintenanceMode   Boolean  @default(false)
  maintenanceMessage String?

  // Payment Settings
  isCodEnabled      Boolean  @default(true)
  isStripeEnabled   Boolean  @default(false)
  isTestMode        Boolean  @default(true)
  stripePublicKey   String?
  stripeSecretKey   String?
  
  isPaymobEnabled   Boolean  @default(false)
  paymobApiKey      String?
  paymobIntegrationId String?
  paymobIframeId    String?
  paymobHmacSecret  String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}